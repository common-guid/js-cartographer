# JS Cartographer / Humanify — Environment Variables
# Copy this file to .env and fill in the values you need.
# .env is gitignored and will never be committed.

# =============================================================================
# LLM Provider API Keys (only the one(s) you intend to use are required)
# =============================================================================

# OpenAI — used by: humanify openai
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1   # Override for Azure or local proxies

# Google Gemini / AIStudio — used by: humanify gemini
# GEMINI_API_KEY=...

# OpenRouter — used by: humanify openrouter
# OPENROUTER_API_KEY=sk-or-...
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# =============================================================================
# Local LLM (node-llama-cpp) — used by: humanify local
# =============================================================================
# No API key needed. Models are downloaded via: humanify download 2b
# Models are stored in ~/.cartographer/models/ by default.
# Specify a custom models directory in .cartographerrc.json:
# { "modelsDirectory": "/custom/path/to/models" }
# You can override the configuration file path here:
# CARTOGRAPHER_CONFIG=path/to/.cartographerrc.json

# =============================================================================
# Test Configuration
# =============================================================================
# Verbose output during test runs (set to any value to enable)
# VERBOSE=1
